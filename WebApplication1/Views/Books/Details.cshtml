@model WebApplication1.Models.Entities.Book

@{
    ViewData["Title"] = "Details";
}

<h2>內容</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10 ">@Model.Id</dd>

        <dt class="col-sm-2">ISBN</dt>
        <dd class="col-sm-10 ">@Model.Isbn</dd>

        <dt class="col-sm-2">書名</dt>
        <dd class="col-sm-10 ">@Model.Title</dd>

        <dt class="col-sm-2">作者</dt>
        <dd class="col-sm-10 ">@(Model.Author ?? "-")</dd>

        <dt class="col-sm-2">建立時間</dt>
        <dd class="col-sm-10 ">@Model.CreatedAt</dd>

        <dt class="col-sm-2">封面圖片</dt>
    </dl>
</div>

@if (!string.IsNullOrWhiteSpace(@Model.BCoverFileName))
{
    <img id="preview" src="/upload/@Model.BCoverFileName" alt="封面預覽" class="mt-5 " max-width:500px;" />
}
else
{
    <dd class="col-sm-10 ">尚無封面圖片</dd>
}


<div class="d-flex justify-content-end gap-2">
    <a asp-action="Index" class="btn btn-secondary">取消</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">編輯</a>
</div>


